#!/bin/bash
##############################################################################
# Gradle start up script for UN*X
# 
# Note: This is a minimal wrapper script. In a real project, you would use
# the gradle-wrapper.jar. This script serves as a placeholder that delegates
# to the system gradle or can be replaced with the full wrapper.
##############################################################################

# Attempt to set APP_HOME
# Resolve links: $0 may be a link
PRG="$0"
# Need this for relative symlinks.
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`"/$link"
    fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
APP_HOME="`pwd -P`"
cd "$SAVED" >/dev/null

# Add default JVM options here
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Check if gradle-wrapper.jar exists
if [ -f "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" ] ; then
    exec java $DEFAULT_JVM_OPTS -jar "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" "$@"
else
    echo "WARNING: gradle-wrapper.jar not found. Using system gradle."
    echo "To fix: Run 'gradle wrapper' to generate the wrapper JAR."
    exec gradle "$@"
fi
